{
  "manifest_version": 3,
  "name": "HoloCards Admin Core",
  "short_name": "HC Admin",
  "version": "1.0.0",
  "description": "Cuartel General Administrativo de HoloCards — Back-Office PWA",

  "icons": {
    "16":  "icon-16.png",
    "32":  "icon-32.png",
    "48":  "icon-48.png",
    "128": "icon-128.png"
  },

  "action": {
    "default_title": "HC Admin",
    "default_popup": "index.html",
    "default_icon": {
      "16":  "icon-16.png",
      "32":  "icon-32.png",
      "48":  "icon-48.png",
      "128": "icon-128.png"
    }
  },

  "permissions": ["tabs"],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },

  "web_accessible_resources": [
    {
      "resources": ["assets/*", "fonts/*", "*.png", "*.webmanifest"],
      "matches": ["<all_urls>"]
    }
  ]
}
